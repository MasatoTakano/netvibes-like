# .env.docker.example
# Docker Compose の nuxt-app コンテナへ注入する環境変数テンプレート
# 使い方: cp .env.docker.example .env.docker
#         その後、各変数を実環境に合わせて編集してください
#
# 注意:
# - docker compose の labels 内 ${...} 展開には、このファイルではなく .env が使われる。
# - Traefik の TRAEFIK_DASHBOARD_AUTH_USERS は .env に定義すること。

# Prisma が参照するデータベース接続文字列
# Docker Compose 構成では postgres サービスを参照
DATABASE_URL="postgresql://memoapp:memoapp_dev@postgres:5432/memoapp"

# Better Auth 設定
# BETTER_AUTH_SECRET: セッション署名用シークレット
# 【重要】本番(production)では必須。32文字以上であること。
#   生成コマンド: openssl rand -hex 32
#   未設定の場合、起動時にプロセスが終了します。
BETTER_AUTH_SECRET=""
# BETTER_AUTH_URL: アプリのベースURL（本番ドメインを指定）
# 【重要】本番(production)では https:// 必須。
BETTER_AUTH_URL="https://memo-app.local"

# Resend メール送信設定
# パスワードリセット・メール確認機能に必要。
# 開発環境で未設定の場合、メール内容がコンソールに出力されます。
# 本番では必須。Resendダッシュボード (https://resend.com/api-keys) で取得してください。
RESEND_API_KEY=""
# 送信元メールアドレス。Resendで認証済みのドメインを使用してください。
EMAIL_FROM=""

# Google OAuth 設定
# Google Cloud Console → APIとサービス → 認証情報 → OAuth クライアント ID で取得。
# 承認済みリダイレクトURIに {BETTER_AUTH_URL}/api/auth/callback/google を追加すること。
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
