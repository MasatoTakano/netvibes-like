# .env.docker.example
# Docker Compose でコンテナを起動する際の環境変数テンプレート
# 使い方: cp .env.docker.example .env.docker
#         その後、各変数を実環境に合わせて編集してください

# Prisma が参照するデータベース接続文字列
# Docker Compose 構成では SQLite ファイルを /app/.data/dev.db にマウントする
DATABASE_URL="file:/app/.data/dev.db"

# Lucia セッション Cookie の secure 属性
# 本番（HTTPS）環境では true に設定すること
NUXT_LUCIA_COOKIE_SECURE=true

# Traefik ダッシュボードの BasicAuth 認証情報
# 以下コマンドで生成した文字列を設定する:
#   htpasswd -nbB admin 'your-password'
# Docker Compose が変数展開するため、$ は $$ にエスケープすること:
#   TRAEFIK_DASHBOARD_AUTH_USERS="admin:$$2y$$05$$..."
TRAEFIK_DASHBOARD_AUTH_USERS=""
