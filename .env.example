# .env.example
# ローカル開発用環境変数テンプレート
# 使い方: cp .env.example .env
#         その後、各変数を開発環境に合わせて編集してください

# Prisma が参照するデータベース接続文字列
# ローカル開発では SQLite ファイルを プロジェクトルート/.data/dev.db に配置する
DATABASE_URL="file:../.data/dev.db"

# Lucia セッション Cookie の secure 属性
# ローカル開発（HTTP）では false、本番（HTTPS）では true に設定する
NUXT_LUCIA_COOKIE_SECURE=false
