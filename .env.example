# .env.example
# ローカル開発 / Docker Compose 変数展開用テンプレート
# 使い方: cp .env.example .env
#         その後、各変数を開発環境に合わせて編集してください

# Prisma が参照するデータベース接続文字列
# ローカル開発（ホスト側 npm run dev）では localhost の PostgreSQL を参照
DATABASE_URL="postgresql://memoapp:memoapp_dev@localhost:5432/memoapp"

# Better Auth 設定
# BETTER_AUTH_SECRET: セッション署名用シークレット
# 【重要】本番(production)では必須。32文字以上であること。
#   生成コマンド: openssl rand -hex 32
#   開発時は未設定でも起動しますが警告が出ます。
BETTER_AUTH_SECRET=""
# BETTER_AUTH_URL: アプリのベースURL
# 【重要】本番(production)では https:// 必須。
BETTER_AUTH_URL="http://localhost:3000"

# Resend メール送信設定
# 開発環境で未設定の場合、メール内容がコンソールに出力されます（実際の送信は行われません）。
# 本番では必須。Resendダッシュボード (https://resend.com/api-keys) で取得してください。
RESEND_API_KEY=""
# 送信元メールアドレス。Resendで認証済みのドメインを使用してください。
# 開発時は未設定で onboarding@resend.dev が使用されます。
EMAIL_FROM=""

# Google OAuth 設定
# Google Cloud Console → APIとサービス → 認証情報 → OAuth クライアント ID で取得。
# 承認済みリダイレクトURIに {BETTER_AUTH_URL}/api/auth/callback/google を追加すること。
# 未設定の場合、Googleログインボタンは機能しません。
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Traefik ダッシュボードの BasicAuth 認証情報
# docker compose の labels で ${TRAEFIK_DASHBOARD_AUTH_USERS} として展開されるため、
# .env.docker ではなく .env に定義する必要がある。
# 以下コマンドで生成した文字列を設定する:
#   htpasswd -nbB admin 'your-password'
# Docker Compose が変数展開するため、$ は $$ にエスケープすること:
#   TRAEFIK_DASHBOARD_AUTH_USERS="admin:$$2y$$05$$...":
TRAEFIK_DASHBOARD_AUTH_USERS=""
